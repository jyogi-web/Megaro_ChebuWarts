{
  "mcpServers": {
    "unity-mcp": {
      "command": "bash",
      "args": ["-c", "$HOME/.unity/relay/relay_mac_arm64.app/Contents/MacOS/relay_mac_arm64 --mcp"]
    }
  }
}

// SETUP INSTRUCTIONS:
// 1. Copy this file to .mcp.json in the same directory
// 2. Update the relay path based on your OS:
//
// macOS (Intel):
//   "args": ["-c", "$HOME/.unity/relay/relay_mac_x64.app/Contents/MacOS/relay_mac_x64 --mcp"]
//
// macOS (Apple Silicon/ARM64):
//   "args": ["-c", "$HOME/.unity/relay/relay_mac_arm64.app/Contents/MacOS/relay_mac_arm64 --mcp"]
//
// Windows:
//   "command": "cmd",
//   "args": ["/c", "%USERPROFILE%\\.unity\\relay\\relay_windows_x64.exe --mcp"]
//
// Linux:
//   "args": ["-c", "$HOME/.unity/relay/relay_linux_x64 --mcp"]
